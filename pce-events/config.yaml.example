# Pretty Cool Events configuration for plugger
# Copy to ~/.plugger/volumes/pce-events/config/config.yaml (or /tmp/plugger/volumes/...)

config:
  # PCE connection
  pce: your-pce.example.com
  pce_port: 8443
  pce_api_user: api_xxxxxxxxxxxx
  pce_api_secret: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  pce_org: 1
  pce_poll_interval: 10
  pce_timeout: 60
  verify_tls: false

  # Web UI (served on port 8443)
  httpd: true
  httpd_listener_address: 0.0.0.0
  httpd_listener_port: 8443
  httpd_username: ""
  httpd_password: ""

  default_template: default.html

  # Output plugin configuration
  plugin_config:
    PCEStdout:
      prepend: ""
    # PCESlack:
    #   slack_bot_token: xoxb-your-token
    # PCETeams:
    #   webhook_url: https://outlook.office.com/webhook/...
    # PCEMail:
    #   smtp_host: smtp.example.com
    #   smtp_port: 587
    #   smtp_user: alerts@example.com
    #   smtp_password: password
    #   from_addr: alerts@example.com
    #   to_addr: team@example.com
    # PCEWebhook:
    #   url: https://your-endpoint.example.com/webhook
    # PCEPagerDuty:
    #   routing_key: your-routing-key

# Watchers — map event type regex patterns to output plugins
watchers:
  # Catch-all: log everything to stdout
  ".*":
    - status: "*"
      plugin: PCEStdout
      extra_data:
        template: default.html

  # Example: security events to Slack
  # "^(user\\.login|user\\.logout|sec_policy\\.)":
  #   - plugin: PCESlack
  #     extra_data:
  #       channel: "#security-alerts"
  #       template: default.html
