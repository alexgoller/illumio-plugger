  #   days: [mon, tue, wed, thu, fri]
  #   start_time: "18:00"
  #   end_time: "07:00"  # overnight window
  #   action_in_window: enable
  #   action_outside: disable
  #   enabled: false
  #   comment: "[rule-scheduler] After hours RDP"
